# Copy to .env and fill in. The agent runs fully offline with the mock provider
# (LLM_PROVIDER=mock) — no key needed — so you can try it before wiring Qwen.

# Provider: "qwen" for the real Qwen Cloud model, "mock" for the offline demo/tests.
LLM_PROVIDER=mock

# --- Qwen Cloud (OpenAI-compatible endpoint) ---
# Get a key + free hackathon credits: https://www.qwencloud.com/challenge/hackathon/voucher-application
QWEN_API_KEY=
# OpenAI-compatible base URL for Qwen Cloud / Alibaba Cloud Model Studio.
# Verify the exact host on the "First API Call" doc; this is the standard form:
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Model id — e.g. qwen-max, qwen-plus, qwen-turbo, qwen3-...
QWEN_MODEL=qwen-plus

# HTTP server port for the web approval UI
PORT=8787
